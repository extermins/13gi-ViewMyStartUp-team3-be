generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  nickname  String
  password  String

  companies   Company[]
  comparisons Comparison[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  category    String?
  logoUrl     String?

  revenue         Int?
  totalInvestment Int?

  // 프론트엔드에 인증이 없으므로 optional — 인증 도입 시 NOT NULL로 변경
  ownerId Int?
  owner   User? @relation(fields: [ownerId], references: [id], onDelete: SetNull)

  comparisonCompanies ComparisonCompany[]
  investments      Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comparison {
  id    Int    @id @default(autoincrement())
  title String

  // 프론트엔드에 인증이 없으므로 optional — 인증 도입 시 NOT NULL로 변경
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  companies ComparisonCompany[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ComparisonCompany {
  comparisonId Int
  companyId    Int

  comparison Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([comparisonId, companyId])
}

model Investment {
  id Int @id @default(autoincrement())

  companyId Int
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  amount   Int
  investor String?
  round    String?

  // MVP용 수정/삭제 확인 비밀번호
  // 실제 서비스에서는 절대 평문 저장 금지, bcrypt 해시 저장 필요
  password String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
